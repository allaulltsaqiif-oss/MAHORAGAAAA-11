### Database Functions & Triggers

```sql
-- Generate kode_ortu 8 karakter alfanumerik
CREATE OR REPLACE FUNCTION public.generate_kode_ortu()
RETURNS TRIGGER AS $$
DECLARE
  chars TEXT := 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; -- hapus karakter mirip (0/O, 1/I)
  new_kode TEXT := '';
  i INT;
BEGIN
  LOOP
    new_kode := '';
    FOR i IN 1..8 LOOP
      new_kode := new_kode || substr(chars, floor(random() * length(chars) + 1)::int, 1);
    END LOOP;
    -- Tambah separator untuk keterbacaan: XXXX-XXXX
    new_kode := substr(new_kode, 1, 4) || '-' || substr(new_kode, 5, 4);
    EXIT WHEN NOT EXISTS (SELECT 1 FROM public.siswa WHERE kode_ortu = new_kode);
  END LOOP;
  NEW.kode_ortu := new_kode;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_generate_kode_ortu
  BEFORE INSERT ON public.siswa
  FOR EACH ROW
  WHEN (NEW.kode_ortu IS NULL OR NEW.kode_ortu = '')
  EXECUTE FUNCTION public.generate_kode_ortu();

-- Update timestamp otomatis
CREATE OR REPLACE FUNCTION public.update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_kepulangan_updated_at
  BEFORE UPDATE ON public.kepulangan
  FOR EACH ROW EXECUTE FUNCTION public.update_updated_at();
```

