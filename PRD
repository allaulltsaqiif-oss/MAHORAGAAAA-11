## 8. Skema Database Lengkap

> **Wajib:** Aktifkan Row-Level Security (RLS) di semua tabel.

### Tabel: profiles

```sql
CREATE TABLE public.profiles (
  id            UUID REFERENCES auth.users(id) ON DELETE CASCADE PRIMARY KEY,
  role          VARCHAR(20) NOT NULL CHECK (role IN ('guru', 'ortu')),
  nama          TEXT NOT NULL,
  nip           VARCHAR(10) UNIQUE NULL,
  kode_anak     VARCHAR(10) UNIQUE NULL,          -- 8 karakter alfanumerik
  nomor_wa      VARCHAR(15) NULL,
  created_at    TIMESTAMPTZ DEFAULT NOW() NOT NULL
);

CREATE INDEX idx_profiles_role ON public.profiles(role);
CREATE INDEX idx_profiles_nip ON public.profiles(nip);
CREATE INDEX idx_profiles_kode ON public.profiles(kode_anak);

ALTER TABLE public.profiles ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Users can view own profile"
  ON public.profiles FOR SELECT USING (auth.uid() = id);
CREATE POLICY "Users can update own profile"
  ON public.profiles FOR UPDATE USING (auth.uid() = id);
```

### Tabel: kelas

```sql
CREATE TABLE public.kelas (
  id            UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  guru_id       UUID REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
  nama_kelas    VARCHAR(50) NOT NULL,
  tahun_ajaran  VARCHAR(9) DEFAULT '2025/2026',
  created_at    TIMESTAMPTZ DEFAULT NOW() NOT NULL
);

ALTER TABLE public.kelas ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Guru can CRUD their own kelas"
  ON public.kelas FOR ALL USING (auth.uid() = guru_id);
```

### Tabel: siswa

```sql
CREATE TABLE public.siswa (
  id            UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  kelas_id      UUID REFERENCES public.kelas(id) ON DELETE CASCADE NOT NULL,
  nama          TEXT NOT NULL,
  nis           VARCHAR(20) NULL,
  kode_ortu     VARCHAR(10) UNIQUE NOT NULL,      -- 8 karakter alfanumerik acak
  nomor_wa_ortu VARCHAR(15) NULL,
  created_at    TIMESTAMPTZ DEFAULT NOW() NOT NULL
);

CREATE INDEX idx_siswa_kelas ON public.siswa(kelas_id);
CREATE INDEX idx_siswa_kode_ortu ON public.siswa(kode_ortu);

ALTER TABLE public.siswa ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Guru can manage siswa in their kelas"
  ON public.siswa FOR ALL
  USING (EXISTS (
    SELECT 1 FROM public.kelas
    WHERE kelas.id = siswa.kelas_id AND kelas.guru_id = auth.uid()
  ));
```

### Tabel: perkembangan

```sql
CREATE TABLE public.perkembangan (
  id                UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  siswa_id          UUID REFERENCES public.siswa(id) ON DELETE CASCADE NOT NULL,
  minggu            VARCHAR(10) NOT NULL,          -- format 'YYYY-WW'
  kreativitas       VARCHAR(10) NOT NULL CHECK (kreativitas IN ('hijau', 'kuning', 'merah')),
  kolaborasi        VARCHAR(10) NOT NULL CHECK (kolaborasi IN ('hijau', 'kuning', 'merah')),
  berpikir_kritis   VARCHAR(10) NOT NULL CHECK (berpikir_kritis IN ('hijau', 'kuning', 'merah')),
  komunikasi        VARCHAR(10) NOT NULL CHECK (komunikasi IN ('hijau', 'kuning', 'merah')),
  catatan_guru      TEXT NULL,
  updated_at        TIMESTAMPTZ DEFAULT NOW() NOT NULL,
  UNIQUE(siswa_id, minggu)
);

CREATE INDEX idx_perkembangan_siswa ON public.perkembangan(siswa_id);
CREATE INDEX idx_perkembangan_minggu ON public.perkembangan(minggu);

ALTER TABLE public.perkembangan ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Guru can manage perkembangan for their siswa"
  ON public.perkembangan FOR ALL
  USING (EXISTS (
    SELECT 1 FROM public.siswa
    JOIN public.kelas ON kelas.id = siswa.kelas_id
    WHERE siswa.id = perkembangan.siswa_id AND kelas.guru_id = auth.uid()
  ));
CREATE POLICY "Orang tua can view perkembangan of their anak"
  ON public.perkembangan FOR SELECT
  USING (EXISTS (
    SELECT 1 FROM public.siswa
    WHERE siswa.id = perkembangan.siswa_id
    AND siswa.kode_ortu = (SELECT kode_anak FROM public.profiles WHERE id = auth.uid())
  ));
```

### Tabel: kepulangan

```sql
CREATE TABLE public.kepulangan (
  id              UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  siswa_id        UUID REFERENCES public.siswa(id) ON DELETE CASCADE NOT NULL,
  tanggal         DATE NOT NULL,
  estimasi_pulang TIME NULL,                       -- diset guru di pagi hari
