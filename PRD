## 10. Sistem Notifikasi & Real-Time

### 10.1 Notifikasi Kepulangan Real-Time

```typescript
// hooks/useRealtimeKepulangan.ts
export function useRealtimeKepulangan(siswaId: string, onUpdate: (data: KepulanganRow) => void) {
  const supabase = useSupabase();
  useEffect(() => {
    const channel = supabase
      .channel(`kepulangan-${siswaId}`)
      .on(
        'postgres_changes',
        { event: '*', schema: 'public', table: 'kepulangan', filter: `siswa_id=eq.${siswaId}` },
        (payload) => onUpdate(payload.new as KepulanganRow)
      )
      .subscribe();
    return () => { supabase.removeChannel(channel); };
  }, [siswaId]);
}
```

